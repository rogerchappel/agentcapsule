{
  "name": "agentcapsule",
  "version": "0.1.0",
  "description": "Local-first context capsules for coding-agent handoffs.",
  "type": "module",
  "bin": {
    "agentcapsule": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test \"dist/test/**/*.test.js\"",
    "smoke": "bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm test && npm run check && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agents",
    "cli",
    "handoff",
    "archive",
    "manifest"
  ],
  "author": "Roger's OSS factory",
  "license": "MIT",
  "dependencies": {
    "minimatch": "^10.2.5",
    "tar": "^7.5.15"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rogerchappel/agentcapsule"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/agentcapsule/issues"
  },
  "homepage": "https://github.com/rogerchappel/agentcapsule#readme"
}
